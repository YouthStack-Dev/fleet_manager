# =============================================================
# .env.example — template for all environments
# Copy the relevant section to .env and fill in real values.
# NEVER commit .env to git — only commit this example file.
# =============================================================


# =============================================================
# LOCAL DEVELOPMENT  (uvicorn / direct run)
# =============================================================
ENV=development

POSTGRES_HOST=localhost
POSTGRES_USER=fleetadmin
POSTGRES_PASSWORD=REPLACE_WITH_YOUR_LOCAL_DB_PASSWORD
POSTGRES_DB=fleet_db
POSTGRES_PORT=5432
# DATABASE_URL is auto-built; override only if needed:
# DATABASE_URL=postgresql://fleetadmin:PASSWORD@localhost:5432/fleet_db

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_REAL_SECRET_KEY
TOKEN_EXPIRY_HOURS=24

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
USE_REDIS=0

STORAGE_TYPE=filesystem
LOCAL_DEV_STORAGE_PATH=./local_storage
MAX_FILE_SIZE_MB=5

EMAIL_ENABLED=false
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SENDER_EMAIL=
SENDER_NAME=Fleet Manager Admin
SUPPORT_EMAIL=

FCM_ENABLED=false
FIREBASE_KEY_PATH=./app/firebase/firebase_key.json

OAUTH2_URL=http://localhost:8000/api/v1/auth/introspect
X_INTROSPECT_SECRET=REPLACE_WITH_A_SECRET
OAUTH2_ENV=dev


# =============================================================
# DOCKER COMPOSE  (docker-compose.yml)
# These values are injected into all ${VAR} placeholders.
# Put this section in the .env file at the project root.
# =============================================================
ENV=development

POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SECRET_KEY=REPLACE_WITH_A_REAL_SECRET_KEY
X_INTROSPECT_SECRET=REPLACE_WITH_A_SECRET

SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD
SENDER_EMAIL=your-email@example.com
SUPPORT_EMAIL=your-email@example.com

REDIS_HOST=redis_server
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
USE_REDIS=1

TOKEN_EXPIRY_HOURS=1
OAUTH2_ENV=dev


# =============================================================
# PRODUCTION  (docker-compose_prod.yaml / service.prod.env)
# Use GitHub Actions secrets or a secrets manager to populate.
# NEVER hardcode real values here.
# =============================================================
ENV=production

POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PRODUCTION_PASSWORD
SECRET_KEY=REPLACE_WITH_PRODUCTION_SECRET_KEY

SMTP_USERNAME=your-prod-email@example.com
SMTP_PASSWORD=REPLACE_WITH_PRODUCTION_APP_PASSWORD
SENDER_EMAIL=your-prod-email@example.com
SUPPORT_EMAIL=your-prod-email@example.com

REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

TOKEN_EXPIRY_HOURS=1
OAUTH2_ENV=production

STORAGE_TYPE=filesystem
PROD_SERVER_STORAGE_PATH=/var/lib/fleet/storage
MAX_FILE_SIZE_MB=10

FIREBASE_KEY_PATH=/app/app/firebase/firebase_key.json

TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=
